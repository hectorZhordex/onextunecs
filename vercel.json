{
  "buildCommand": "pnpm --filter @workspace/onetune run build",
  "outputDirectory": "artifacts/onetune/dist/public",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
